{
  "name": "corvina-device-sdk",
  "private": true,
  "version": "1.0.0",
  "description": "Corvina Device SDK",
  "license": "MIT",
  "scripts": {
    "build": "lerna run build",
    "start:dev": "lerna run start:dev --parallel",
    "test": "lerna run test --parallel",
    "lint": "lerna run lint --parallel",
    "format": "lerna run format --parallel",
    "prepublish": "yarn run build",
    "publish": "yarn run prepublish && lerna publish --no-private"
  },
  "workspaces": [
    "apps/example",
    "libs/device-client"
  ],
  "dependencies": {
    "lerna": "^9.0.6"
  },
  "packageManager": "yarn@3.2.1"
}
